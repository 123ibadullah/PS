{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @workspace/api-server --filter @workspace/phishshield --parallel run dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck:ml": "powershell -NoProfile -Command \"Set-Location ..; python -m mypy --config-file backend/mypy.ini\"",
    "typecheck:all": "npx tsc --noEmit && pnpm typecheck:ml",
    "typecheck": "pnpm run typecheck:libs && pnpm --filter @workspace/api-server --filter @workspace/phishshield --filter @workspace/mockup-sandbox --filter @workspace/scripts --if-present run typecheck",
    "qa:system": "pnpm --filter @workspace/scripts run qa:system",
    "qa:ui": "pnpm --filter @workspace/scripts run qa:ui",
    "validate:final": "pnpm --filter @workspace/scripts run final-validation"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
