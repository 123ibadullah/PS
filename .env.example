# ============================================================
# PhishShield — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit your real .env file
# ============================================================

# Python ML Service URL (FastAPI)
# Local dev: http://127.0.0.1:8000
# Production: https://your-ml-service.com
PHISHSHIELD_TRANSFORMER_URL=http://127.0.0.1:8000

# Express API Port
PORT=5000

# Auth token for dev/testing (change in production)
DEV_SANDBOX_KEY=dev-sandbox-key
API_KEY=dev-sandbox-key
PHISHSHIELD_API_KEY=dev-sandbox-key

# Node environment
NODE_ENV=development

# Python FastAPI port (used when starting uvicorn)
ML_SERVICE_PORT=8000

# CORS (dashboard + Chrome extension preflight)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://mail.google.com
# Optional override; default allows chrome-extension://* and localhost
# CORS_ALLOWED_ORIGIN_REGEX=^(chrome-extension|moz-extension)://.*$

# Database
DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=

# Internal API auth (Express -> Python)
PHISHSHIELD_INTERNAL_API_KEY=change-me

# ML provider tuning
PHISHSHIELD_ML_TIMEOUT_MS=5000
PHISHSHIELD_ML_CIRCUIT_FAILURE_THRESHOLD=3
PHISHSHIELD_ML_CIRCUIT_OPEN_MS=30000
PHISHSHIELD_TRANSFORMER_TIMEOUT_MS=5000
PHISHSHIELD_SECUREBERT_URL=
PHISHSHIELD_SECUREBERT_TIMEOUT_MS=5000
PHISHSHIELD_MURIL_URL=
PHISHSHIELD_MURIL_TIMEOUT_MS=5000

# Retraining thresholds
PHISHSHIELD_RETRAIN_SAMPLE_THRESHOLD=25
PHISHSHIELD_RETRAIN_DAY_THRESHOLD=7

# Frontier / LLM fallback
PHISHSHIELD_FRONTIER_MODE=smart
PHISHSHIELD_LLM_TIMEOUT_MS=7000
PHISHSHIELD_FRONTIER_TIMEOUT_MS=7000
PHISHSHIELD_LLM_API_URL=
PHISHSHIELD_FRONTIER_URL=
PHISHSHIELD_LOCAL_MODEL_URL=
PHISHSHIELD_LLM_PROVIDER=
PHISHSHIELD_FRONTIER_PROVIDER=
PHISHSHIELD_LLM_MODEL=
PHISHSHIELD_FRONTIER_MODEL=
PHISHSHIELD_LOCAL_MODEL_NAME=
PHISHSHIELD_LLM_API_MODE=chat
PHISHSHIELD_FRONTIER_API_MODE=chat
PHISHSHIELD_LLM_HEADERS_JSON=
PHISHSHIELD_FRONTIER_HEADERS_JSON=
PHISHSHIELD_LLM_API_KEY=
PHISHSHIELD_FRONTIER_API_KEY=
PHISHSHIELD_LLM_API_KEY_HEADER=Authorization
PHISHSHIELD_FRONTIER_API_KEY_HEADER=Authorization
PHISHSHIELD_LLM_API_KEY_SCHEME=Bearer
PHISHSHIELD_FRONTIER_API_KEY_SCHEME=Bearer
PHISHSHIELD_LLM_PROMPT=

# Threat intel domain lists
PHISHSHIELD_BLOCKED_DOMAINS=
PHISHSHIELD_IOC_DOMAINS=

# Frontend / tooling
BASE_PATH=/
ENABLE_RUNTIME_ERROR_OVERLAY=false
VITE_API_PROXY_TARGET=http://localhost:5000
PHISH_BACKEND_URL=http://127.0.0.1:5000
PHISH_FRONTEND_URL=http://127.0.0.1:5173

# Python backend integrations
# Required on Render/Docker if ML weights are not baked into the image (see backend/.dockerignore).
# Used to download IndicBERT/SecureBERT/MuRIL on first startup when model folders are missing.
HF_TOKEN=
# Fine-tuned classifier checkpoints (HF Model repos, not the Space repo)
PHISHSHIELD_SECUREBERT_HF_REPO=Mohd1314234123/phishshield-securebert
PHISHSHIELD_MURIL_HF_REPO=Mohd1314234123/phishshield-muril
VT_API_KEY=
ENVIRONMENT=development
VIRUSTOTAL_API_KEY=
LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/auto
OPENROUTER_MODEL=
LLM_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_KEY=
OPENROUTER_FALLBACK_MODELS=
GEMINI_MODEL=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Python backend timeouts (seconds)
SCAN_PROCESS_TIMEOUT_SECONDS=45
NETWORK_IO_TIMEOUT_SECONDS=0.75
VT_HTTP_TIMEOUT_SECONDS=0.75
VT_RETRY_WAIT_SECONDS=0.15
LLM_TIMEOUT_SECONDS=2.8
OPENROUTER_TIMEOUT_SECONDS=2.8
GEMINI_TIMEOUT_SECONDS=2.8

# Optional local model artifact directories
PHISHSHIELD_SECUREBERT_ARTIFACT_DIR=
PHISHSHIELD_MURIL_ARTIFACT_DIR=
