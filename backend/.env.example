HF_TOKEN=your_huggingface_token_here
VT_API_KEY=your_virustotal_api_key_here
VIRUSTOTAL_API_KEY=
ENVIRONMENT=development

# Internal API auth (optional)
PHISHSHIELD_INTERNAL_API_KEY=

# LLM provider (optional; used only when configured)
LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/auto
OPENROUTER_MODEL=
OPENROUTER_FALLBACK_MODELS=

# Keys (set at least one for your chosen provider)
LLM_API_KEY=your_llm_api_key_here
OPENROUTER_API_KEY=
OPENROUTER_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=

# Timeouts (seconds)
SCAN_PROCESS_TIMEOUT_SECONDS=45
NETWORK_IO_TIMEOUT_SECONDS=0.75
VT_HTTP_TIMEOUT_SECONDS=0.75
VT_RETRY_WAIT_SECONDS=0.15
LLM_TIMEOUT_SECONDS=2.8
OPENROUTER_TIMEOUT_SECONDS=2.8
GEMINI_TIMEOUT_SECONDS=2.8

# Explainability on /scan-email (TF-IDF linear-weights → LIME → heuristic; SHAP opt-in)
PHISHSHIELD_TRY_SHAP_ON_SCAN=0
PHISHSHIELD_SHAP_TIMEOUT_SECONDS=2.5
PHISHSHIELD_SHAP_MAX_EVALS=64
EXPLAIN_TIMEOUT_SECONDS=4
# Local dev: set PHISHSHIELD_TRY_SHAP_ON_SCAN=1 to attempt SHAP within EXPLAIN_TIMEOUT_SECONDS

# HuggingFace token (optional; helps download missing indicbert config files)
HF_TOKEN=

# Transformer warmup at startup (seconds)
PHISHSHIELD_PROVIDER_WARMUP_SECONDS=180
